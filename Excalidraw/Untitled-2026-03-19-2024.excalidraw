    {
      "id": "QHbDOwUninSD3kIDxmH0u",
      "type": "text",
      "x": 376.075453830504,
      "y": 2595.5773911347387,
      "width": 1227.691357430652,
      "height": 301.1707239684828,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "cross-hatch",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "az",
      "roundness": null,
      "seed": 570430064,
      "version": 1084,
      "versionNonce": 862329459,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774085638210,
      "link": null,
      "locked": false,
      "text": "быстрая память малого объема\nКэш-линии\ncache hit ratio\ncache miss \n\nобъединенная и разделенная кэш-память (unified and split cache, I-cache, D-cache)\nпри конвейерной архитекутуре обращение к данным и к командам должно осуществляться одноверменно, потому сейчас\nсуществуют отдельные I-cache и D-cache\n\nуровни кэш-памяти и их расположение\n\nПодробнее см. Глава 4 Таненбаум Архитектура компьютера",
      "fontSize": 20.078048264565517,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "быстрая память малого объема\nКэш-линии\ncache hit ratio\ncache miss \n\nобъединенная и разделенная кэш-память (unified and split cache, I-cache, D-cache)\nпри конвейерной архитекутуре обращение к данным и к командам должно осуществляться одноверменно, потому сейчас существуют отдельные I-cache и D-cache\n\nуровни кэш-памяти и их расположение\n\nПодробнее см. Глава 4 Таненбаум Архитектура компьютера",
      "autoResize": false,
      "lineHeight": 1.25
    },
