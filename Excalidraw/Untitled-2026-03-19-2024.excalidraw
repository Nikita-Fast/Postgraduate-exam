      "updated": 1774085369740,
      "link": null,
      "locked": false,
      "text": "Шины",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Шины",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "hViT3XfM8re5CHE1p22VL",
      "type": "text",
      "x": 373.5884008650851,
      "y": 2967.6593361298314,
      "width": 1191.3119766494506,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "cross-hatch",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b02",
      "roundness": null,
      "seed": 278409840,
      "version": 318,
      "versionNonce": 751653299,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774085410480,
      "link": null,
      "locked": false,
      "text": "Шина ISA (Industry Standard Architecture) - шина от IBM\nPCI (Peripherial Component Interconnect) - разработана Intel, параллельная шина шириной 32 бита. Имеет отдельные\nлинии для прерываний",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Шина ISA (Industry Standard Architecture) - шина от IBM\nPCI (Peripherial Component Interconnect) - разработана Intel, параллельная шина шириной 32 бита. Имеет отдельные линии для прерываний",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "8ErsvHnGCuRnbc68OJrlm",
      "type": "image",
      "x": 510.3650079626757,
      "y": 3025.928375997055,
      "width": 606.8910137313833,
      "height": 251.83307461287606,
      "angle": 0,
      "strokeColor": "transparent",
      "backgroundColor": "transparent",
      "fillStyle": "cross-hatch",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b03",
      "roundness": null,
      "seed": 1090515568,
      "version": 276,
      "versionNonce": 1045201053,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774085377520,
      "link": null,
      "locked": false,
      "status": "saved",
      "fileId": "9d0e0ce42757e2353a8eab47126292d5decebd0b",
